USE_REAL_PROVIDERS=true
GROQ_API_KEY=groq-api-key
GROQ_MULTIMODAL_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Egyptian-dialect TTS -- default already points at a working free public
# Gradio Space, override only if you switch to a different one.
EGYPTIAN_TTS_SPACE_ID=omarelshehy/NAMAA-Egyptian-Voice

# Egyptian currency specialist detector (optional) -- leave ROBOFLOW_API_KEY
# blank to keep using the general VLM for currency questions. Fill in once
# you have a free Roboflow account + API key (see README.md for setup steps).
ROBOFLOW_API_KEY=roboflow-api-key
ROBOFLOW_CURRENCY_PROJECT=egyptian-currency-psnkr
ROBOFLOW_CURRENCY_VERSION=1
BE_MY_EYE_API_KEY=11111
# Created by Vercel CLI
VERCEL_OIDC_TOKEN=vercel-api-key